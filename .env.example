# ============================================================================
#  ai-contact-backend — пример переменных окружения
#  Скопируйте в .env:  cp .env.example .env
#  Сервис запускается БЕЗ каких-либо секретов (дефолты рассчитаны на демо).
# ============================================================================

# --- Приложение ---
APP_NAME="AI Contact Backend"
APP_ENV=development            # development | production | test
DEBUG=true
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs

# --- CORS (через запятую; * — разрешить всё, только для демо) ---
CORS_ORIGINS=*

# --- База данных ---
# По умолчанию — Postgres из docker-compose. Для локального запуска без Docker
# можно указать sqlite+aiosqlite:///./app.db
DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/contacts

# --- Rate limiting ---
RATE_LIMIT_CONTACT="5/minute"  # формат slowapi: <кол-во>/<период>
REDIS_URL=                     # пусто → in-memory лимитер (для демо достаточно)

# --- AI-провайдер ---
# mock      — rule-based анализ, работает без ключей и сети (ДЕФОЛТ)
# anthropic — реальный Claude (нужен ключ; из РФ требуется прокси)
AI_PROVIDER=mock
AI_TIMEOUT_SECONDS=10
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_BASE_URL=          # прокси-шлюз, если нужен доступ из РФ

# --- Email ---
# console — письма пишутся в лог и в logs/emails/*.eml (ДЕФОЛТ, без SMTP)
# smtp    — реальная отправка через SMTP
EMAIL_BACKEND=console
EMAIL_OWNER=owner@example.com          # кому уходит письмо-уведомление
EMAIL_FROM="AI Contact <no-reply@example.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
